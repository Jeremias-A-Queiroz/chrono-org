        <h2>Visão Global (Todos os Contextos)</h2>
        <canvas id="chart-global-progress" data-global-url="./assets/data/global-dashboard-202602.json"></canvas>
    </div>

    <div class="chart-container">
        <h2>Atividades Pessoais (Detalhe)</h2>
        <canvas id="chart-timeline" data-url="./assets/data/index-202602.json"></canvas>
    </div>

    <!-- Scripts Locais -->
    <script src="../assets/js/chart.js"></script> <!-- Agora Local -->
    <script src="../assets/js/chart-utils.js"></script>
    <script src="../assets/js/global-dashboard.js"></script>
    <script src="../assets/js/context-dashboard.js"></script>
